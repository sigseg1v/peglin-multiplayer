<Project>
  <PropertyGroup>
    <TargetFramework>net462</TargetFramework>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RestoreAdditionalProjectSources>https://api.nuget.org/v3/index.json;https://nuget.bepinex.dev/v3/index.json</RestoreAdditionalProjectSources>
  </PropertyGroup>

  <!-- Reference assemblies for building net462 on Linux -->
  <ItemGroup>
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies.net462" Version="1.0.3" PrivateAssets="all" />
  </ItemGroup>

  <!-- Paths to game assemblies -->
  <PropertyGroup>
    <GameManagedDir>$(MSBuildThisFileDirectory)../release/Peglin_Data/Managed</GameManagedDir>
  </PropertyGroup>
</Project>
